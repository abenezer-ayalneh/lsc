{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"color": {
			"palette": [
				{ "slug": "brand-orange", "color": "#fb6304", "name": "Brand Orange" },
				{ "slug": "brand-blue",   "color": "#149ED9", "name": "Brand Blue" },
				{ "slug": "brand-green",  "color": "#00844A", "name": "Brand Green" },
				{ "slug": "brand-teal",   "color": "#85C3BE", "name": "Brand Teal" },
				{ "slug": "brand-yellow", "color": "#FFD527", "name": "Brand Yellow" },
				{ "slug": "brand-magenta","color": "#A30037", "name": "Brand Magenta" },
				{ "slug": "brand-navy",   "color": "#014A7F", "name": "Brand Navy" },
				{ "slug": "ink",          "color": "#232323", "name": "Ink" },
				{ "slug": "smoke",        "color": "#f7f7f7", "name": "Smoke" },
				{ "slug": "white",        "color": "#ffffff", "name": "White" }
			]
		},
		"typography": {
			"fontFamilies": [
				{ "slug": "heading", "name": "League Spartan", "fontFamily": "'League Spartan', system-ui, sans-serif" },
				{ "slug": "body",    "name": "Quicksand",      "fontFamily": "'Quicksand', system-ui, sans-serif" }
			],
			"fontSizes": [
				{ "slug": "small",   "size": "0.95rem", "name": "Small" },
				{ "slug": "medium",  "size": "1.125rem", "name": "Medium" },
				{ "slug": "large",   "size": "1.6rem",  "name": "Large" },
				{ "slug": "x-large", "size": "2.4rem",  "name": "Extra Large" },
				{ "slug": "huge",    "size": "3.4rem",  "name": "Huge" }
			]
		},
		"layout": {
			"contentSize": "780px",
			"wideSize": "1180px"
		}
	},
	"styles": {
		"typography": { "fontFamily": "var(--wp--preset--font-family--body)" },
		"elements": {
			"link":   { "color": { "text": "var(--wp--preset--color--brand-orange)" } },
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontWeight": "800", "textTransform": "uppercase", "lineHeight": "1.05" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontWeight": "800", "textTransform": "uppercase", "lineHeight": "1.1" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontWeight": "700" } }
		}
	}
}
