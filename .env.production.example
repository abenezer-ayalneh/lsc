# ─── Production WordPress environment (Ubuntu VPS) ─────────────────
# Copy to `.env` on the server, replace every `change_me` value, then:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Generate strong passwords: openssl rand -base64 32
# Never commit `.env` — it is gitignored.

# Database
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=lsc_wp
MYSQL_USER=lsc
MYSQL_PASSWORD=change_me

# WordPress admin (created automatically on first run)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me
WP_ADMIN_EMAIL=info@lsportsc.org

# Site — use your live HTTPS URL (no trailing slash)
WP_SITE_URL=https://www.lsportsc.org
WP_SITE_TITLE=Lewisham Sports Consortium

# Internal port (Caddy on the host reverse-proxies to 127.0.0.1:8080)
WP_PORT=8080
