# ─── Local WordPress dev environment ───────────────────────────────
# Copy to `.env`, change the passwords, then `docker compose up -d`.
# Do NOT use these credentials in production.

# Database
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=lsc_wp
MYSQL_USER=lsc
MYSQL_PASSWORD=change_me

# WordPress admin (created automatically on first run)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me
WP_ADMIN_EMAIL=info@lsportsc.org

# Site
WP_SITE_URL=http://localhost:8080
WP_SITE_TITLE=Lewisham Sports Consortium

# Host ports (change if something else is already using them)
WP_PORT=8080
PHPMYADMIN_PORT=8081
MAILHOG_UI_PORT=8025
